{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Alias de rutas: sistema (@) y perfil activo (@profile) */
    "paths": {
      "@/*": ["./src/*"],
      "@profile": ["./profiles/escuela/index.ts"],
      "@profile/*": ["./profiles/escuela/*"]
    },

    /* Linting estricto */
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src", "src/vite-env.d.ts", "profiles"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
